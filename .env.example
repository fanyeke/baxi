# ⚠️ SECURITY WARNING ⚠️
# This file contains placeholder values for sensitive configuration.
# NEVER commit the real .env file to version control.
# Copy this file to .env and replace all placeholders with real values.
# Generate a strong API_BEARER_TOKEN: python3 -c "import secrets; print(secrets.token_urlsafe(32))"

FEISHU_APP_ID=YOUR_APP_ID
FEISHU_APP_SECRET=YOUR_APP_SECRET
FEISHU_BASE_APP_TOKEN=YOUR_APP_TOKEN
FEISHU_CHAT_ID=YOUR_CHAT_ID

# LLM API Key for AI Decision Engine (OpenAI-compatible)
LLM_API_KEY=sk-your-key-here

# API Bearer token for backend API authentication
# MUST be at least 32 characters and not a common weak token
API_BEARER_TOKEN=REPLACE_ME

# Default user identity returned by auth dependency
DEFAULT_USER=qoder

# CORS origins for API (comma-separated, default: http://localhost:5173)
# NEVER set to * (wildcard) as it allows any website to make cross-origin requests
CORS_ORIGINS=http://localhost:5173

# Trusted proxy IPs for rate limiting (comma-separated)
TRUSTED_PROXY_IPS=127.0.0.1,::1

# Enable Swagger/OpenAPI docs (set to 1 to enable at /docs)
# Disable in production to reduce attack surface
ENABLE_DOCS=0

# Debug mode: show full traceback on 500 errors (set to 1 to enable)
# NEVER enable in production as it may leak sensitive information
DEBUG=0
