# ⚠️ SECURITY WARNING ⚠️
# This file contains placeholder values for sensitive configuration.
# NEVER commit the real .env file to version control.
# Copy this file to .env and replace all placeholders with real values.
# Generate a strong token: openssl rand -base64 32

# ──────────────────────────────────────────────
# PostgreSQL (shared with Docker Compose)
# ──────────────────────────────────────────────
DATABASE_URL=postgres://baxi:baxi_dev@localhost:5432/baxi?sslmode=disable
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=baxi
POSTGRES_USER=baxi
POSTGRES_PASSWORD=baxi_dev

# ──────────────────────────────────────────────
# Go API Server
# ──────────────────────────────────────────────
API_PORT=8080
LOG_LEVEL=info

# API bearer token for backend API authentication
# MUST be at least 32 characters and not a common weak token
API_BEARER_TOKEN=REPLACE_ME

# CORS allowed origins (comma-separated, optional)
# Default: http://localhost:5173,http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ──────────────────────────────────────────────
# Feishu Integration
# ──────────────────────────────────────────────
FEISHU_APP_ID=YOUR_APP_ID
FEISHU_APP_SECRET=YOUR_APP_SECRET
FEISHU_BASE_APP_TOKEN=YOUR_APP_TOKEN
FEISHU_CHAT_ID=YOUR_CHAT_ID
FEISHU_WEBHOOK_URL=

# ──────────────────────────────────────────────
# LLM / AI Decision Engine (Phase 6)
# ──────────────────────────────────────────────
LLM_ENABLED=false
LLM_API_KEY=sk-your-key-here
LLM_PROVIDER=disabled
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
DECISION_DEFAULT_ROLE=agent_readonly
DECISION_REQUIRE_HUMAN_REVIEW=true

# ──────────────────────────────────────────────
# GitHub Integration
# ──────────────────────────────────────────────
GITHUB_TOKEN=

# ──────────────────────────────────────────────
# Phase 7: Review / Action / Outbox
# ──────────────────────────────────────────────
ACTION_EXECUTION_ENABLED=false
OUTBOX_DISPATCH_ENABLED=false
OUTBOX_DISPATCH_DRY_RUN=true
ACTION_APPLY_DRY_RUN=true
WORKER_TICK_INTERVAL=30s
WORKER_BATCH_SIZE=10
