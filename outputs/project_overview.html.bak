<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Olist巴西电商数据分析项目概览 - 经营分析与决策沙盘">
  <title>Olist 电商经营分析与决策沙盘项目 | 项目概览</title>
  <style>
    /* ========================================
       CSS RESET & BASE
       ======================================== */
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      /* Colors */
      --bg-primary: #f5f7fa;
      --bg-card: #ffffff;
      --sidebar-bg: #1e293b;
      --sidebar-active: #0ea5e9;
      --text-primary: #1e293b;
      --text-secondary: #64748b;
      --text-muted: #94a3b8;
      --text-white: #f8fafc;
      --accent-blue: #2563eb;
      --accent-teal: #0ea5e9;
      --accent-amber: #f59e0b;
      --accent-green: #10b981;
      --accent-red: #ef4444;
      --border-color: #e2e8f0;
      --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
      --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
      --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
      
      /* Typography */
      --font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      --font-mono: 'SF Mono', Monaco, Inconsolata, 'Roboto Mono', Consolas, 'Courier New', monospace;
      
      /* Spacing */
      --sidebar-width: 240px;
      --content-max-width: 1000px;
      --spacing-xs: 4px;
      --spacing-sm: 8px;
      --spacing-md: 16px;
      --spacing-lg: 24px;
      --spacing-xl: 32px;
      --spacing-2xl: 48px;
      
      /* Transitions */
      --transition-fast: 150ms ease;
      --transition-normal: 200ms ease;
    }

    html {
      scroll-behavior: smooth;
      font-size: 16px;
    }

    body {
      font-family: var(--font-family);
      background-color: var(--bg-primary);
      color: var(--text-primary);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* Skip to content link */
    .skip-link {
      position: absolute;
      top: -40px;
      left: 0;
      background: var(--accent-blue);
      color: white;
      padding: var(--spacing-sm) var(--spacing-md);
      z-index: 10000;
      transition: top var(--transition-fast);
    }

    .skip-link:focus {
      top: 0;
    }

    /* ========================================
       LAYOUT
       ======================================== */
    .app-container {
      display: flex;
      min-height: 100vh;
    }

    /* ========================================
       SIDEBAR
       ======================================== */
    .sidebar {
      position: fixed;
      left: 0;
      top: 0;
      width: var(--sidebar-width);
      height: 100vh;
      background: var(--sidebar-bg);
      color: var(--text-white);
      z-index: 100;
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: rgba(255,255,255,0.2) transparent;
    }

    .sidebar::-webkit-scrollbar {
      width: 6px;
    }

    .sidebar::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.2);
      border-radius: 3px;
    }

    .sidebar-header {
      padding: var(--spacing-lg);
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .logo {
      display: flex;
      align-items: center;
      gap: var(--spacing-sm);
      font-size: 1.125rem;
      font-weight: 600;
      margin-bottom: var(--spacing-xs);
    }

    .logo-icon {
      width: 32px;
      height: 32px;
      background: linear-gradient(135deg, var(--accent-teal), var(--accent-blue));
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
    }

    .logo-subtitle {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-left: 40px;
    }

    .nav-menu {
      padding: var(--spacing-md) 0;
    }

    .nav-item {
      display: block;
      padding: var(--spacing-sm) var(--spacing-lg);
      color: var(--text-muted);
      text-decoration: none;
      font-size: 0.875rem;
      border-left: 3px solid transparent;
      transition: all var(--transition-fast);
      cursor: pointer;
    }

    .nav-item:hover {
      color: var(--text-white);
      background: rgba(255,255,255,0.05);
    }

    .nav-item.active {
      color: var(--accent-teal);
      border-left-color: var(--accent-teal);
      background: rgba(14, 165, 233, 0.1);
    }

    .sidebar-footer {
      position: sticky;
      bottom: 0;
      background: var(--sidebar-bg);
      padding: var(--spacing-md) var(--spacing-lg);
      border-top: 1px solid rgba(255,255,255,0.1);
    }

    .back-to-top {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--spacing-sm);
      width: 100%;
      padding: var(--spacing-sm);
      background: rgba(255,255,255,0.1);
      border: none;
      border-radius: 6px;
      color: var(--text-white);
      font-size: 0.875rem;
      cursor: pointer;
      transition: background var(--transition-fast);
    }

    .back-to-top:hover {
      background: rgba(255,255,255,0.15);
    }

    /* Mobile menu toggle */
    .mobile-menu-toggle {
      display: none;
      position: fixed;
      top: var(--spacing-md);
      left: var(--spacing-md);
      z-index: 200;
      width: 44px;
      height: 44px;
      background: var(--sidebar-bg);
      border: none;
      border-radius: 8px;
      color: white;
      font-size: 1.25rem;
      cursor: pointer;
    }

    /* ========================================
       MAIN CONTENT
       ======================================== */
    .main-content {
      flex: 1;
      margin-left: var(--sidebar-width);
      min-height: 100vh;
    }

    .content-wrapper {
      max-width: var(--content-max-width);
      margin: 0 auto;
      padding: var(--spacing-2xl);
    }

    /* ========================================
       SECTIONS
       ======================================== */
    section {
      margin-bottom: var(--spacing-2xl);
      scroll-margin-top: var(--spacing-xl);
    }

    .section-header {
      margin-bottom: var(--spacing-lg);
      padding-bottom: var(--spacing-md);
      border-bottom: 2px solid var(--border-color);
    }

    h1 {
      font-size: 2rem;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: var(--spacing-sm);
      line-height: 1.2;
    }

    h2 {
      font-size: 1.5rem;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: var(--spacing-md);
      display: flex;
      align-items: center;
      gap: var(--spacing-sm);
    }

    h2 .section-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      background: var(--accent-blue);
      color: white;
      border-radius: 6px;
      font-size: 0.875rem;
      font-weight: 700;
    }

    h3 {
      font-size: 1.125rem;
      font-weight: 600;
      color: var(--text-primary);
      margin: var(--spacing-lg) 0 var(--spacing-md);
    }

    p {
      margin-bottom: var(--spacing-md);
      color: var(--text-secondary);
    }

    /* ========================================
       CARDS
       ======================================== */
    .card {
      background: var(--bg-card);
      border-radius: 12px;
      box-shadow: var(--shadow-md);
      padding: var(--spacing-lg);
      margin-bottom: var(--spacing-lg);
      transition: box-shadow var(--transition-normal);
    }

    .card:hover {
      box-shadow: var(--shadow-lg);
    }

    .card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: var(--spacing-md);
    }

    .card-title {
      font-size: 1.125rem;
      font-weight: 600;
      color: var(--text-primary);
    }

    .card-subtitle {
      font-size: 0.875rem;
      color: var(--text-secondary);
      margin-top: var(--spacing-xs);
    }

    /* KPI Cards */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: var(--spacing-md);
      margin: var(--spacing-lg) 0;
    }

    .kpi-card {
      background: var(--bg-card);
      border-radius: 12px;
      padding: var(--spacing-lg);
      text-align: center;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border-color);
      transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    }

    .kpi-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }

    .kpi-value {
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--accent-blue);
      line-height: 1;
    }

    .kpi-label {
      font-size: 0.75rem;
      color: var(--text-secondary);
      margin-top: var(--spacing-sm);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* ========================================
       BADGES & LABELS
       ======================================== */
    .badge {
      display: inline-flex;
      align-items: center;
      gap: var(--spacing-xs);
      padding: var(--spacing-xs) var(--spacing-sm);
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 500;
    }

    .badge-success {
      background: rgba(16, 185, 129, 0.1);
      color: var(--accent-green);
    }

    .badge-info {
      background: rgba(37, 99, 235, 0.1);
      color: var(--accent-blue);
    }

    .badge-warning {
      background: rgba(245, 158, 11, 0.1);
      color: var(--accent-amber);
    }

    .badge-danger {
      background: rgba(239, 68, 68, 0.1);
      color: var(--accent-red);
    }

    .badge-ghost {
      background: rgba(100, 116, 139, 0.1);
      color: var(--text-secondary);
    }

    .term-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 2px 8px;
      background: rgba(14, 165, 233, 0.1);
      color: var(--accent-teal);
      border-radius: 4px;
      font-size: 0.75rem;
      font-weight: 500;
      cursor: pointer;
      transition: background var(--transition-fast);
    }

    .term-badge:hover {
      background: rgba(14, 165, 233, 0.2);
    }

    /* ========================================
       TABLES
       ======================================== */
    .table-container {
      overflow-x: auto;
      border-radius: 8px;
      border: 1px solid var(--border-color);
      margin: var(--spacing-md) 0;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.875rem;
    }

    thead {
      background: var(--bg-primary);
    }

    th {
      padding: var(--spacing-sm) var(--spacing-md);
      text-align: left;
      font-weight: 600;
      color: var(--text-primary);
      border-bottom: 1px solid var(--border-color);
      white-space: nowrap;
    }

    td {
      padding: var(--spacing-sm) var(--spacing-md);
      border-bottom: 1px solid var(--border-color);
      color: var(--text-secondary);
    }

    tbody tr:last-child td {
      border-bottom: none;
    }

    tbody tr:hover {
      background: rgba(241, 245, 249, 0.5);
    }

    /* ========================================
       HIGHLIGHT BOXES
       ======================================== */
    .highlight-box {
      padding: var(--spacing-md);
      border-radius: 8px;
      border-left: 4px solid;
      margin: var(--spacing-md) 0;
    }

    .highlight-box.info {
      background: rgba(37, 99, 235, 0.05);
      border-color: var(--accent-blue);
    }

    .highlight-box.warning {
      background: rgba(245, 158, 11, 0.05);
      border-color: var(--accent-amber);
    }

    .highlight-box.danger {
      background: rgba(239, 68, 68, 0.05);
      border-color: var(--accent-red);
    }

    .highlight-box.success {
      background: rgba(16, 185, 129, 0.05);
      border-color: var(--accent-green);
    }

    /* ========================================
       GRID LAYOUTS
       ======================================== */
    .grid-2 {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--spacing-lg);
    }

    .grid-3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--spacing-lg);
    }

    /* ========================================
       TIMELINE
       ======================================== */
    .timeline {
      display: flex;
      align-items: center;
      gap: var(--spacing-sm);
      padding: var(--spacing-lg) 0;
      overflow-x: auto;
    }

    .timeline-item {
      flex-shrink: 0;
      padding: var(--spacing-sm) var(--spacing-md);
      background: var(--bg-card);
      border-radius: 8px;
      border: 2px solid var(--border-color);
      text-align: center;
      min-width: 120px;
      cursor: pointer;
      transition: all var(--transition-fast);
    }

    .timeline-item:hover {
      border-color: var(--accent-blue);
      transform: translateY(-2px);
    }

    .timeline-item .phase-num {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--accent-blue);
      text-transform: uppercase;
    }

    .timeline-item .phase-name {
      font-size: 0.75rem;
      color: var(--text-secondary);
      margin-top: 2px;
    }

    .timeline-arrow {
      color: var(--text-muted);
      font-size: 1.25rem;
    }

    /* ========================================
       CHARTS
       ======================================== */
    .chart-container {
      background: var(--bg-card);
      border-radius: 12px;
      padding: var(--spacing-lg);
      margin: var(--spacing-lg) 0;
    }

    .chart-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: var(--spacing-md);
    }

    .bar-chart {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-sm);
    }

    .bar-row {
      display: flex;
      align-items: center;
      gap: var(--spacing-md);
    }

    .bar-label {
      flex-shrink: 0;
      width: 120px;
      font-size: 0.875rem;
      color: var(--text-secondary);
      text-align: right;
    }

    .bar-track {
      flex: 1;
      height: 24px;
      background: var(--bg-primary);
      border-radius: 4px;
      overflow: hidden;
    }

    .bar-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent-blue), var(--accent-teal));
      border-radius: 4px;
      transition: width 0.5s ease;
    }

    .bar-value {
      flex-shrink: 0;
      width: 60px;
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--text-primary);
    }

    /* Funnel Chart */
    .funnel-chart {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--spacing-sm);
    }

    .funnel-stage {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 48px;
      color: white;
      font-weight: 600;
      border-radius: 4px;
      position: relative;
    }

    .funnel-stage.mql {
      width: 80%;
      background: var(--accent-blue);
    }

    .funnel-stage.closed {
      width: 50%;
      background: var(--accent-teal);
    }

    .funnel-stage.activated {
      width: 30%;
      background: var(--accent-green);
    }

    .funnel-label {
      font-size: 0.875rem;
    }

    .funnel-conversion {
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    /* Pareto Chart */
    .pareto-chart {
      display: flex;
      align-items: flex-end;
      justify-content: center;
      gap: var(--spacing-md);
      height: 200px;
      padding: var(--spacing-md) 0;
    }

    .pareto-bar {
      width: 60px;
      background: linear-gradient(180deg, var(--accent-blue), var(--accent-teal));
      border-radius: 4px 4px 0 0;
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-end;
      padding-bottom: var(--spacing-sm);
    }

    .pareto-value {
      font-size: 0.75rem;
      font-weight: 600;
      color: white;
      margin-bottom: 4px;
    }

    .pareto-label {
      position: absolute;
      bottom: -24px;
      font-size: 0.75rem;
      color: var(--text-secondary);
      text-align: center;
      width: 80px;
    }

    /* Scatter Plot */
    .scatter-plot {
      position: relative;
      height: 200px;
      border-left: 1px solid var(--border-color);
      border-bottom: 1px solid var(--border-color);
      margin: var(--spacing-md) 0 var(--spacing-lg);
    }

    .scatter-point {
      position: absolute;
      width: 8px;
      height: 8px;
      background: var(--accent-blue);
      border-radius: 50%;
      transform: translate(-50%, 50%);
    }

    .axis-label {
      position: absolute;
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    /* ========================================
       SEARCH
       ======================================== */
    .search-container {
      position: sticky;
      top: 0;
      background: var(--bg-primary);
      padding: var(--spacing-md) 0;
      z-index: 50;
      border-bottom: 1px solid var(--border-color);
      margin-bottom: var(--spacing-lg);
    }

    .search-input {
      width: 100%;
      padding: var(--spacing-sm) var(--spacing-md);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      font-size: 0.875rem;
      background: var(--bg-card);
      transition: border-color var(--transition-fast);
    }

    .search-input:focus {
      outline: none;
      border-color: var(--accent-blue);
    }

    .search-results {
      margin-top: var(--spacing-sm);
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    /* ========================================
       MODALS
       ======================================== */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      visibility: hidden;
      transition: all var(--transition-normal);
    }

    .modal-overlay.active {
      opacity: 1;
      visibility: visible;
    }

    .modal {
      background: var(--bg-card);
      border-radius: 12px;
      max-width: 600px;
      width: 90%;
      max-height: 80vh;
      overflow: auto;
      transform: scale(0.95);
      transition: transform var(--transition-normal);
    }

    .modal-overlay.active .modal {
      transform: scale(1);
    }

    .modal-header {
      padding: var(--spacing-lg);
      border-bottom: 1px solid var(--border-color);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .modal-title {
      font-size: 1.25rem;
      font-weight: 600;
    }

    .modal-close {
      background: none;
      border: none;
      font-size: 1.5rem;
      color: var(--text-muted);
      cursor: pointer;
      padding: var(--spacing-xs);
      line-height: 1;
    }

    .modal-close:hover {
      color: var(--text-primary);
    }

    .modal-body {
      padding: var(--spacing-lg);
    }

    /* ========================================
       EXPANDABLE SECTIONS
       ======================================== */
    .expandable {
      border: 1px solid var(--border-color);
      border-radius: 8px;
      margin: var(--spacing-md) 0;
    }

    .expandable-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: var(--spacing-md);
      cursor: pointer;
      background: var(--bg-primary);
      border-radius: 8px 8px 0 0;
      transition: background var(--transition-fast);
    }

    .expandable-header:hover {
      background: rgba(241, 245, 249, 0.8);
    }

    .expandable-title {
      font-weight: 600;
      color: var(--text-primary);
    }

    .expandable-toggle {
      color: var(--text-muted);
      transition: transform var(--transition-fast);
    }

    .expandable.expanded .expandable-toggle {
      transform: rotate(180deg);
    }

    .expandable-content {
      display: none;
      padding: var(--spacing-md);
      border-top: 1px solid var(--border-color);
    }

    .expandable.expanded .expandable-content {
      display: block;
    }

    /* ========================================
       SCENARIO CARDS
       ======================================== */
    .scenario-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--spacing-md);
      margin: var(--spacing-lg) 0;
    }

    .scenario-card {
      background: var(--bg-card);
      border-radius: 12px;
      padding: var(--spacing-lg);
      border: 2px solid var(--border-color);
      cursor: pointer;
      transition: all var(--transition-fast);
    }

    .scenario-card:hover {
      border-color: var(--accent-blue);
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }

    .scenario-header {
      display: flex;
      align-items: center;
      gap: var(--spacing-sm);
      margin-bottom: var(--spacing-md);
    }

    .scenario-id {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      background: var(--accent-blue);
      color: white;
      border-radius: 8px;
      font-weight: 700;
      font-size: 0.875rem;
    }

    .scenario-name {
      font-weight: 600;
      color: var(--text-primary);
    }

    .scenario-impact {
      display: flex;
      align-items: center;
      gap: var(--spacing-sm);
      margin-top: var(--spacing-sm);
    }

    .impact-arrow {
      color: var(--accent-green);
      font-weight: 700;
    }

    .impact-value {
      font-weight: 600;
      color: var(--accent-green);
    }

    /* ========================================
       CONCLUSION CARDS
       ======================================== */
    .conclusion-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: var(--spacing-md);
    }

    .conclusion-card {
      background: var(--bg-card);
      border-radius: 12px;
      padding: var(--spacing-lg);
      border-left: 4px solid var(--accent-teal);
      box-shadow: var(--shadow-sm);
      transition: box-shadow var(--transition-fast);
    }

    .conclusion-card:hover {
      box-shadow: var(--shadow-md);
    }

    .conclusion-icon {
      font-size: 1.5rem;
      margin-bottom: var(--spacing-sm);
    }

    .conclusion-text {
      font-size: 0.9375rem;
      color: var(--text-primary);
      line-height: 1.5;
    }

    /* ========================================
       NEXT STEPS
       ======================================== */
    .step-list {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-md);
    }

    .step-item {
      display: flex;
      align-items: flex-start;
      gap: var(--spacing-md);
      padding: var(--spacing-lg);
      background: var(--bg-card);
      border-radius: 12px;
      box-shadow: var(--shadow-sm);
    }

    .step-number {
      flex-shrink: 0;
      width: 40px;
      height: 40px;
      background: linear-gradient(135deg, var(--accent-blue), var(--accent-teal));
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
    }

    .step-content {
      flex: 1;
    }

    .step-title {
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: var(--spacing-xs);
    }

    .step-desc {
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .step-timeline {
      flex-shrink: 0;
      font-size: 0.75rem;
      color: var(--accent-teal);
      font-weight: 500;
    }

    /* ========================================
       FLOWCHART
       ======================================== */
    .flowchart {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--spacing-sm);
      padding: var(--spacing-lg);
      background: var(--bg-primary);
      border-radius: 8px;
      font-family: var(--font-mono);
      font-size: 0.875rem;
      line-height: 1.4;
      white-space: pre;
      overflow-x: auto;
    }

    /* ========================================
       RESPONSIVE
       ======================================== */
    @media (max-width: 1024px) {
      .grid-3 {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 768px) {
      .sidebar {
        transform: translateX(-100%);
        transition: transform var(--transition-normal);
      }

      .sidebar.open {
        transform: translateX(0);
      }

      .main-content {
        margin-left: 0;
      }

      .mobile-menu-toggle {
        display: block;
      }

      .content-wrapper {
        padding: var(--spacing-lg);
      }

      h1 {
        font-size: 1.5rem;
      }

      h2 {
        font-size: 1.25rem;
      }

      .grid-2, .grid-3 {
        grid-template-columns: 1fr;
      }

      .kpi-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .timeline {
        flex-direction: column;
        align-items: flex-start;
      }

      .timeline-arrow {
        transform: rotate(90deg);
      }

      .scenario-grid {
        grid-template-columns: 1fr;
      }

      .conclusion-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 480px) {
      .kpi-grid {
        grid-template-columns: 1fr;
      }

      .bar-label {
        width: 80px;
        font-size: 0.75rem;
      }

      .bar-value {
        width: 50px;
        font-size: 0.75rem;
      }
    }

    /* ========================================
       ACCESSIBILITY
       ======================================== */
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    :focus-visible {
      outline: 2px solid var(--accent-blue);
      outline-offset: 2px;
    }

    /* High contrast mode support */
    @media (prefers-contrast: high) {
      .card, .kpi-card {
        border: 2px solid var(--text-primary);
      }
    }

    /* Reduced motion */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }

      html {
        scroll-behavior: auto;
      }
    }

    /* ========================================
       GLOSSARY POPUP
       ======================================== */
    .glossary-popup {
      position: fixed;
      background: var(--bg-card);
      border-radius: 8px;
      box-shadow: var(--shadow-lg);
      padding: var(--spacing-md);
      max-width: 300px;
      z-index: 1001;
      opacity: 0;
      visibility: hidden;
      transition: all var(--transition-fast);
    }

    .glossary-popup.active {
      opacity: 1;
      visibility: visible;
    }

    .glossary-term {
      font-weight: 600;
      color: var(--accent-blue);
      margin-bottom: var(--spacing-xs);
    }

    .glossary-def {
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    /* ========================================
       PRINT STYLES
       ======================================== */
    @media print {
      .sidebar, .mobile-menu-toggle, .back-to-top, .search-container {
        display: none !important;
      }

      .main-content {
        margin-left: 0;
      }

      .card, .kpi-card {
        break-inside: avoid;
      }
    }
  </style>
</head>
<body>
  <a href="#main-content" class="skip-link">跳转到主要内容</a>
  
  <button class="mobile-menu-toggle" aria-label="打开导航菜单" onclick="toggleSidebar()">☰</button>
  
  <div class="app-container">
    <!-- Sidebar Navigation -->
    <nav class="sidebar" id="sidebar" role="navigation" aria-label="主导航">
      <div class="sidebar-header">
        <div class="logo">
          <div class="logo-icon">📊</div>
          <span>Olist 电商项目</span>
        </div>
        <div class="logo-subtitle">决策沙盘</div>
      </div>
      
      <div class="nav-menu">
        <a href="#overview" class="nav-item active" data-section="overview">项目概览</a>
        <a href="#roadmap" class="nav-item" data-section="roadmap">项目总体路线图</a>
        <a href="#goals" class="nav-item" data-section="goals">研究目标</a>
        <a href="#datasource" class="nav-item" data-section="datasource">数据源与业务背景</a>
        <a href="#phase1" class="nav-item" data-section="phase1">Phase 1：原始数据理解</a>
        <a href="#phase2" class="nav-item" data-section="phase2">Phase 2：数据模型搭建</a>
        <a href="#phase3" class="nav-item" data-section="phase3">Phase 3：整体经营分析</a>
        <a href="#phase4" class="nav-item" data-section="phase4">Phase 4：履约与体验</a>
        <a href="#phase5" class="nav-item" data-section="phase5">Phase 5：营销漏斗与商家增长</a>
        <a href="#phase6" class="nav-item" data-section="phase6">Phase 6：模拟变量设计</a>
        <a href="#phase7" class="nav-item" data-section="phase7">Phase 7：量化模拟引擎</a>
        <a href="#phase7-5" class="nav-item" data-section="phase7-5">Phase 7.5：校准修订</a>
        <a href="#phase8" class="nav-item" data-section="phase8">Phase 8：飞书沙盘结构</a>
        <a href="#conclusions" class="nav-item" data-section="conclusions">核心结论</a>
        <a href="#value" class="nav-item" data-section="value">项目价值</a>
        <a href="#next-steps" class="nav-item" data-section="next-steps">下一步路线</a>
      </div>
      
      <div class="sidebar-footer">
        <button class="back-to-top" onclick="scrollToTop()" aria-label="返回顶部">
          <span>↑</span>
          <span>返回顶部</span>
        </button>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="main-content" id="main-content">
      <div class="content-wrapper">
        
        <!-- Search Bar -->
        <div class="search-container">
          <input 
            type="search" 
            class="search-input" 
            id="searchInput"
            placeholder="搜索项目内容 (如: S02, 延迟率, 卖家激活...)"
            aria-label="搜索项目内容"
          >
          <div class="search-results" id="searchResults"></div>
        </div>

        <!-- Section 1: Project Overview -->
        <section id="overview" class="section-overview">
          <div class="section-header">
            <h1>Olist 电商经营分析与决策沙盘项目</h1>
            <p style="font-size: 1.125rem; color: var(--text-secondary);">
              从公开电商数据出发，构建可供 Waker 使用的经营分析、情景模拟与飞书决策沙盘底座。
            </p>
          </div>
          
          <div class="highlight-box info">
            <strong>页面用途：</strong>本页面用于帮助未参与项目过程的读者，系统理解 Phase 1–8 的分析逻辑、阶段成果与业务价值。
          </div>

          <div style="margin: var(--spacing-lg) 0;">
            <span class="badge badge-success">
              <span>✓</span>
              <span>Phase 1–8 已完成</span>
            </span>
          </div>

          <div class="kpi-grid">
            <div class="kpi-card">
              <div class="kpi-value">8</div>
              <div class="kpi-label">个阶段</div>
            </div>
            <div class="kpi-card">
              <div class="kpi-value">2</div>
              <div class="kpi-label">张核心底表</div>
            </div>
            <div class="kpi-card">
              <div class="kpi-value">40+</div>
              <div class="kpi-label">汇总表</div>
            </div>
            <div class="kpi-card">
              <div class="kpi-value">30+</div>
              <div class="kpi-label">图表</div>
            </div>
            <div class="kpi-card">
              <div class="kpi-value">10</div>
              <div class="kpi-label">what-if 场景</div>
            </div>
            <div class="kpi-card">
              <div class="kpi-value">4</div>
              <div class="kpi-label">已模拟场景</div>
            </div>
          </div>
        </section>

        <!-- Section 2: Project Roadmap -->
        <section id="roadmap">
          <h2>
            <span class="section-number">2</span>
            项目总体路线图
          </h2>
          
          <div class="timeline" role="list" aria-label="项目阶段时间线">
            <div class="timeline-item" onclick="expandPhase('phase1')" role="listitem" tabindex="0">
              <div class="phase-num">Phase 1</div>
              <div class="phase-name">原始数据理解</div>
            </div>
            <span class="timeline-arrow">→</span>
            <div class="timeline-item" onclick="expandPhase('phase2')" role="listitem" tabindex="0">
              <div class="phase-num">Phase 2</div>
              <div class="phase-name">数据模型搭建</div>
            </div>
            <span class="timeline-arrow">→</span>
            <div class="timeline-item" onclick="expandPhase('phase3')" role="listitem" tabindex="0">
              <div class="phase-num">Phase 3</div>
              <div class="phase-name">经营全景分析</div>
            </div>
            <span class="timeline-arrow">→</span>
            <div class="timeline-item" onclick="expandPhase('phase4')" role="listitem" tabindex="0">
              <div class="phase-num">Phase 4</div>
              <div class="phase-name">履约体验分析</div>
            </div>
            <span class="timeline-arrow">→</span>
            <div class="timeline-item" onclick="expandPhase('phase5')" role="listitem" tabindex="0">
              <div class="phase-num">Phase 5</div>
              <div class="phase-name">营销漏斗分析</div>
            </div>
            <span class="timeline-arrow">→</span>
            <div class="timeline-item" onclick="expandPhase('phase6')" role="listitem" tabindex="0">
              <div class="phase-num">Phase 6</div>
              <div class="phase-name">模拟变量设计</div>
            </div>
            <span class="timeline-arrow">→</span>
            <div class="timeline-item" onclick="expandPhase('phase7')" role="listitem" tabindex="0">
              <div class="phase-num">Phase 7</div>
              <div class="phase-name">模拟引擎实现</div>
            </div>
            <span class="timeline-arrow">→</span>
            <div class="timeline-item" onclick="expandPhase('phase8')" role="listitem" tabindex="0">
              <div class="phase-num">Phase 8</div>
              <div class="phase-name">飞书沙盘结构</div>
            </div>
          </div>

          <div class="card">
            <p>项目采用递进式建设路径，从原始数据理解到飞书沙盘结构搭建，形成完整的经营分析与决策支持体系。每个阶段都是下一个阶段的基础，确保分析逻辑的连贯性和可复现性。</p>
          </div>
        </section>

        <!-- Section 3: Research Goals -->
        <section id="goals">
          <h2>
            <span class="section-number">3</span>
            研究目标
          </h2>
          
          <div class="grid-3">
            <div class="card">
              <div class="card-header">
                <div>
                  <div class="card-title">理解经营状态</div>
                  <div class="card-subtitle">Comprehend Business State</div>
                </div>
                <span style="font-size: 2rem;">📊</span>
              </div>
              <p>通过系统分析理解虚拟电商公司的经营全貌，包括订单规模、增长趋势、品类结构、地域分布等核心指标。</p>
            </div>
            
            <div class="card">
              <div class="card-header">
                <div>
                  <div class="card-title">提炼变量体系</div>
                  <div class="card-subtitle">Extract Variable System</div>
                </div>
                <span style="font-size: 2rem;">🔬</span>
              </div>
              <p>从数据中发现可用于决策模拟的关键变量，包括履约变量、体验变量、营销变量等，为 what-if 场景提供数据支撑。</p>
            </div>
            
            <div class="card">
              <div class="card-header">
                <div>
                  <div class="card-title">为沙盘打底</div>
                  <div class="card-subtitle">Build Sandbox Foundation</div>
                </div>
                <span style="font-size: 2rem;">🏗️</span>
              </div>
              <p>为后续 Waker + 飞书多维表格决策沙盘构建数据底座，实现人机协同的智能决策支持系统。</p>
            </div>
          </div>

          <div class="highlight-box success">
            <strong>方法论说明：</strong>本项目不是零散的 EDA（探索性数据分析），而是一条递进式的建设路径。每个阶段都有明确的目标和输出，形成可追溯的分析链条。
          </div>
        </section>

        <!-- Section 4: Data Source -->
        <section id="datasource">
          <h2>
            <span class="section-number">4</span>
            数据源与业务背景
          </h2>
          
          <h3>核心数据表（9张）</h3>
          <div class="table-container">
            <table role="table" aria-label="Olist核心数据表">
              <thead>
                <tr>
                  <th scope="col">数据表</th>
                  <th scope="col">业务意义</th>
                  <th scope="col" style="text-align: right;">行数</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><code>customers</code></td>
                  <td>客户数据</td>
                  <td style="text-align: right;">99,441</td>
                </tr>
                <tr>
                  <td><code>orders</code></td>
                  <td>订单主表</td>
                  <td style="text-align: right;">99,441</td>
                </tr>
                <tr>
                  <td><code>order_items</code></td>
                  <td>订单商品明细</td>
                  <td style="text-align: right;">112,650</td>
                </tr>
                <tr>
                  <td><code>payments</code></td>
                  <td>支付方式与金额</td>
                  <td style="text-align: right;">103,886</td>
                </tr>
                <tr>
                  <td><code>reviews</code></td>
                  <td>用户评价</td>
                  <td style="text-align: right;">99,224</td>
                </tr>
                <tr>
                  <td><code>products</code></td>
                  <td>产品信息</td>
                  <td style="text-align: right;">32,951</td>
                </tr>
                <tr>
                  <td><code>sellers</code></td>
                  <td>卖家数据</td>
                  <td style="text-align: right;">3,095</td>
                </tr>
                <tr>
                  <td><code>geolocation</code></td>
                  <td>地理位置</td>
                  <td style="text-align: right;">1,000,163</td>
                </tr>
                <tr>
                  <td><code>category_translation</code></td>
                  <td>产品类别翻译</td>
                  <td style="text-align: right;">71</td>
                </tr>
              </tbody>
            </table>
          </div>

          <h3>营销漏斗数据表（2张）</h3>
          <div class="table-container">
            <table role="table" aria-label="营销漏斗数据表">
              <thead>
                <tr>
                  <th scope="col">数据表</th>
                  <th scope="col">业务意义</th>
                  <th scope="col" style="text-align: right;">行数</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><code>marketing_qualified_leads</code></td>
                  <td>商家线索（MQL）</td>
                  <td style="text-align: right;">~8,000</td>
                </tr>
                <tr>
                  <td><code>closed_deals</code></td>
                  <td>成交商家</td>
                  <td style="text-align: right;">~1,500</td>
                </tr>
              </tbody>
            </table>
          </div>

          <h3>业务关系图</h3>
          <div class="flowchart" role="img" aria-label="数据关系流程图">
客户 → 订单 → 订单商品 → 商品 ↘ 卖家
                 ↘ 支付
                 ↘ 评价
商家线索 → 成交商家 → 卖家</div>

          <h3>星型模型示意</h3>
          <div class="card" style="text-align: center; padding: var(--spacing-2xl);">
            <svg width="400" height="300" viewBox="0 0 400 300" role="img" aria-label="星型数据模型">
              <!-- Center -->
              <rect x="160" y="120" width="80" height="60" rx="8" fill="#2563eb"/>
              <text x="200" y="155" text-anchor="middle" fill="white" font-size="12" font-weight="600">ORDERS</text>
              
              <!-- Surrounding tables -->
              <rect x="20" y="20" width="80" height="40" rx="6" fill="#0ea5e9" opacity="0.8"/>
              <text x="60" y="45" text-anchor="middle" fill="white" font-size="10">customers</text>
              <line x1="100" y1="60" x2="160" y2="130" stroke="#cbd5e1" stroke-width="2"/>
              
              <rect x="300" y="20" width="80" height="40" rx="6" fill="#0ea5e9" opacity="0.8"/>
              <text x="340" y="45" text-anchor="middle" fill="white" font-size="10">sellers</text>
              <line x1="300" y1="60" x2="240" y2="130" stroke="#cbd5e1" stroke-width="2"/>
              
              <rect x="20" y="130" width="80" height="40" rx="6" fill="#0ea5e9" opacity="0.8"/>
              <text x="60" y="155" text-anchor="middle" fill="white" font-size="10">payments</text>
              <line x1="100" y1="150" x2="160" y2="150" stroke="#cbd5e1" stroke-width="2"/>
              
              <rect x="300" y="130" width="80" height="40" rx="6" fill="#0ea5e9" opacity="0.8"/>
              <text x="340" y="155" text-anchor="middle" fill="white" font-size="10">reviews</text>
              <line x1="300" y1="150" x2="240" y2="150" stroke="#cbd5e1" stroke-width="2"/>
              
              <rect x="160" y="240" width="80" height="40" rx="6" fill="#0ea5e9" opacity="0.8"/>
              <text x="200" y="265" text-anchor="middle" fill="white" font-size="10">order_items</text>
              <line x1="200" y1="240" x2="200" y2="180" stroke="#cbd5e1" stroke-width="2"/>
              
              <rect x="20" y="240" width="80" height="40" rx="6" fill="#0ea5e9" opacity="0.8"/>
              <text x="60" y="265" text-anchor="middle" fill="white" font-size="10">products</text>
              <line x1="60" y1="240" x2="160" y2="170" stroke="#cbd5e1" stroke-width="2"/>
            </svg>
            <p style="margin-top: var(--spacing-md); color: var(--text-muted);">以订单为中心的星型模型设计</p>
          </div>
        </section>
</content>
</main>
</div>
</body>
</html>